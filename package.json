{
  "name": "peripheral",
  "version": "0.1.0",
  "private": true,
  "description": "Peripheral Agent HUD runtime and Mac-connected display tooling.",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "peripheral-hud-runtime"
  ],
  "scripts": {
    "check": "npm run check:public-source && npm run check:sponsor-tools && npm run check:hud",
    "check:public-source": "node tools/check-public-source.mjs",
    "check:sponsor-tools": "node --check tools/sponsor-manual-tool.mjs && node tools/check-sponsor-manual-tools.mjs",
    "check:hud": "npm --prefix peripheral-hud-runtime test",
    "pusher:build": "macos_corebluetooth/peripheral-mac-pusher/build.sh",
    "hud:build": "npm --prefix peripheral-hud-runtime run build",
    "hud:walkthrough": "npm --prefix peripheral-hud-runtime run peripheralctl -- hud --local-display --text"
  }
}
