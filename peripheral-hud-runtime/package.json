{
  "name": "peripheral-hud-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "peripheralctl": "./dist/apps/peripheralctl/src/index.js",
    "hudctl": "./dist/apps/peripheralctl/src/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "peripheralctl": "node dist/apps/peripheralctl/src/index.js",
    "hudctl": "node dist/apps/peripheralctl/src/index.js hudctl",
    "walkthrough": "npm run build && npm run peripheralctl -- walkthrough live-call --local",
    "test": "npm run build && node dist/tests/renderer-smoke.test.js"
  },
  "devDependencies": {
    "@types/node": "^20.17.57",
    "typescript": "^5.9.3"
  }
}
